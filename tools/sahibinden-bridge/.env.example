# Supabase — emlak_daily_leads tablosuna upsert için (UPU platform .env.local
# içindeki SUPABASE_URL + SERVICE_ROLE_KEY ile aynı)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Telegram bot — captcha + scrape-done notification için (opsiyonel).
# Yoksa server sessizce log'a yazar; bot polling /status ile öğrenir.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=1959200543

# Server port (default 3001)
PORT=3001
